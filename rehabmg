        // دالة ديناميكية لحساب معدلات الأداء والـ KPI لكل موظف مبنية على مخرجات دورة المهام الفعالة
        function calculateUserKPI(userName) {
            const userTasks = tasks.filter(t => t.assignees.includes(userName));
            const total = userTasks.length;
            const completed = userTasks.filter(t => t.status === 'مكتملة').length;
            const ongoing = userTasks.filter(t => t.status === 'قيد التنفيذ' || t.status === 'قيد الاستلام').length;
            const pending = userTasks.filter(t => t.status === 'جديدة').length;

            let kpi = total > 0 ? Math.round((completed / total) * 100) : 0;
            
            let colorClass = "bg-red-500";
            let textClass = "text-red-700";
            if (kpi >= 75) { colorClass = "bg-green-600"; textClass = "text-green-700"; }
            else if (kpi >= 40) { colorClass = "bg-amber-500"; textClass = "text-amber-700"; }

            return { kpi, total, completed, ongoing, pending, colorClass, textClass };
        }

