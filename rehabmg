<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rehab MG - نظام إدارة المهام والأداء الذكي (KPI)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { cairo: ['Cairo', 'sans-serif'] },
                    colors: {
                        rmgGreen: '#1B4332',
                        rmgGreenLight: '#2A553E',
                        rmgGold: '#D4AF37',
                    }
                }
            }
        }
    </script>
    <style>body { font-family: 'Cairo', sans-serif; }</style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 min-h-screen pb-28">

    <!-- ================= شاشة تسجيل الدخول ================= -->
    <div id="login-page" class="fixed inset-0 bg-gray-100 flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-3xl p-8 shadow-2xl border border-gray-100 text-center space-y-6">
            <div class="inline-flex w-16 h-16 bg-rmgGreen text-rmgGold rounded-full items-center justify-center shadow-lg text-2xl">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div>
                <h2 class="text-2xl font-bold text-rmgGreen">رحاب أم جي للمقاولات</h2>
                <p class="text-xs text-gray-400 mt-1">منصة التكليفات الذكية وتقييم كفاءة الأداء الرقمي</p>
            </div>

            <div id="login-error" class="hidden bg-red-50 border border-red-200 text-red-600 text-xs p-3 rounded-xl font-semibold">
                <i class="fa-solid fa-triangle-exclamation ml-1"></i> اسم المستخدم أو كلمة المرور غير صحيحة!
            </div>

            <div class="space-y-4 text-right">
                <div>
                    <label class="block text-xs text-gray-500 mb-1 font-semibold">اسم المستخدم</label>
                    <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 flex items-center gap-3 focus-within:border-rmgGreen transition">
                        <i class="fa-solid fa-user text-gray-400 text-sm"></i>
                        <input type="text" id="login-username" placeholder="ادخل اسم المستخدم..." class="w-full bg-transparent outline-none text-sm text-gray-700" autocomplete="username">
                    </div>
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1 font-semibold">كلمة المرور</label>
                    <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 flex items-center gap-3 focus-within:border-rmgGreen transition">
                        <i class="fa-solid fa-lock text-gray-400 text-sm"></i>
                        <input type="password" id="login-password" placeholder="ادخل كلمة المرور..." class="w-full bg-transparent outline-none text-sm text-gray-700" autocomplete="current-password">
                    </div>
                </div>
            </div>

            <button onclick="handleLogin()" class="w-full bg-rmgGreen text-white py-3 rounded-xl font-bold shadow-md hover:bg-emerald-950 transition active:scale-[0.98]">
                تسجيل الدخول <i class="fa-solid fa-arrow-left-to-bracket mr-2 text-xs"></i>
            </button>
            <div class="bg-gray-50 p-2.5 rounded-xl text-[10px] text-gray-400 text-right space-y-0.5 max-h-24 overflow-y-auto border border-gray-100">
                <p class="font-bold border-b pb-0.5 mb-1 text-gray-500">حسابات الدخول للفريق:</p>
                <p>حسام مدحت: hossam / 123456</p>
                <p>محمود حمزة: mahmoud / 123456</p>
                <p>عبدالرحمن سعيد: abdo / 123456</p>
            </div>
        </div>
    </div>

    <!-- ================= محتوى النظام الرئيسي ================= -->
    <div id="main-app-content" class="hidden">
        <!-- شريط الشركة العلوي -->
        <div class="bg-rmgGreen text-white rounded-b-3xl p-6 shadow-lg max-w-xl mx-auto sticky top-0 z-30">
            <div class="flex justify-between items-center mb-4">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-rmgGold rounded-full flex items-center justify-center shadow-md">
                        <i class="fa-solid fa-layer-group text-white text-sm"></i>
                    </div>
                    <h1 class="text-xl font-bold tracking-wide">رحاب أم جي للمقاولات</h1>
                </div>
                <span class="text-xs bg-white/25 px-3 py-1 rounded-full text-gray-200">إصدار 2026 المحسن للإنتاجية</span>
            </div>
            <div class="bg-rmgGreenLight rounded-2xl p-4 flex items-center justify-between shadow-inner">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center border border-white/10">
                        <i class="fa-solid fa-user text-white text-xl"></i>
                    </div>
                    <div>
                        <p class="text-xs text-gray-300">المستعرض المالي والتشغيلي الحالي</p>
                        <h2 id="current-user-display" class="text-base font-bold">حسام مدحت</h2>
                    </div>
                </div>
                <button onclick="handleLogout()" class="text-xs bg-red-600/80 hover:bg-red-700 px-3 py-2 rounded-xl text-white font-bold transition flex items-center gap-1.5">
                    <i class="fa-solid fa-right-from-bracket"></i> خروج
                </button>
            </div>
        </div>

        <!-- المحتوى الرئيسي والأقسام -->
        <main class="max-w-xl mx-auto px-4 mt-6">
            
            <!-- ================= قسم المهام الحالية ================= -->
            <div id="section-tasks" class="app-section space-y-4">
                <div class="flex flex-col gap-2 mb-4">
                    <div class="bg-white flex items-center gap-3 px-4 py-2.5 rounded-xl border border-gray-200 shadow-sm">
                        <i class="fa-solid fa-magnifying-glass text-gray-400"></i>
                        <input type="text" id="search-input" oninput="filterTasks()" placeholder="البحث باسم المهمة، الموظف، أو المشروع..." class="w-full bg-transparent outline-none text-sm text-gray-700">
                    </div>
                    <div id="active-filter-badge" class="hidden bg-amber-50 border border-amber-200 text-amber-800 p-2.5 rounded-xl flex justify-between items-center text-xs">
                        <span id="filter-text">يتم عرض مهام محددة</span>
                        <button onclick="clearActiveFilter()" class="bg-amber-200 hover:bg-amber-300 px-2 py-1 rounded-md font-bold transition">عرض الكل</button>
                    </div>
                </div>
                <h3 class="text-lg font-bold text-rmgGreen mb-3 flex justify-between items-center">
                    <span>دورة حياة المهام الحالية</span>
                    <span id="task-count" class="text-xs bg-gray-200 text-gray-700 px-2.5 py-0.5 rounded-full">0</span>
                </h3>
                <div id="tasks-container" class="space-y-4"></div>
            </div>

            <!-- ================= قسم المشاريع ================= -->
            <div id="section-projects" class="app-section hidden space-y-4">
                <h3 class="text-lg font-bold text-rmgGreen"><i class="fa-solid fa-diagram-project ml-2"></i>المشاريع الجارية (اضغط لعرض المهام)</h3>
                <div id="projects-container" class="space-y-3"></div>
            </div>

            <!-- ================= قسم القطاعات ================= -->
            <div id="section-sectors" class="app-section hidden space-y-4">
                <h3 class="text-lg font-bold text-rmgGreen"><i class="fa-solid fa-chart-pie ml-2"></i>قطاعات العمل الهندسية (اضغط لعرض المهام)</h3>
                <div id="sectors-container" class="space-y-3"></div>
            </div>

            <!-- ================= قسم المستودع والمخزون ================= -->
            <div id="section-inventory" class="app-section hidden space-y-4">
                <h3 class="text-lg font-bold text-rmgGreen"><i class="fa-solid fa-warehouse ml-2"></i>إدارة المستودع ومخزون المعدات</h3>
                
                <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-sm space-y-3">
                    <h4 class="text-sm font-bold text-gray-700 border-b border-gray-100 pb-2"><i class="fa-solid fa-box-open text-rmgGold ml-1"></i> توريد معدة / مادة جديدة للمستودع</h4>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">اسم المعدة / الأداة</label>
                            <input type="text" id="inv-item-name" placeholder="مثال: دريل هيلتي شحن" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">الكمية المتوفرة</label>
                            <input type="number" id="inv-item-qty" placeholder="مثال: 10" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                    </div>
                    <button onclick="addInventoryItem()" class="w-full bg-rmgGreen text-white py-2 rounded-xl text-sm font-bold hover:bg-emerald-900 transition shadow-sm">إضافة للمستودع</button>
                </div>

                <div class="bg-white p-4 rounded-2xl border border-gray-200 shadow-sm">
                    <h4 class="text-xs font-bold text-gray-400 mb-3">حالة المواد والمعدات داخل المستودع الحالي</h4>
                    <div class="overflow-x-auto">
                        <table class="w-full text-right text-sm">
                            <thead>
                                <tr class="border-b border-gray-100 text-gray-400 text-xs">
                                    <th class="pb-2">المعدة / المادة</th>
                                    <th class="pb-2 text-center">الرصيد الإجمالي</th>
                                    <th class="pb-2 text-center">المتاح حالياً</th>
                                </tr>
                            </thead>
                            <tbody id="inventory-table-body" class="divide-y divide-gray-50"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ================= قسم الفريق و معدلات الـ KPI ================= -->
            <div id="section-team" class="app-section hidden space-y-4">
                <h3 class="text-lg font-bold text-rmgGreen flex items-center justify-between">
                    <span><i class="fa-solid fa-users-gear ml-2"></i>لوحة الأداء وكفاءة الفريق (KPIs)</span>
                </h3>
                
                <!-- لوحة مؤشرات الأداء السريعة للأفراد -->
                <div class="bg-emerald-950 text-white p-4 rounded-2xl border border-emerald-900 shadow-md">
                    <div class="flex items-center gap-2 mb-2 text-rmgGold font-bold text-sm">
                        <i class="fa-solid fa-calculator"></i>
                        <span>قاعدة احتساب كفاءة المهام والمؤشر (KPI)</span>
                    </div>
                    <p class="text-gray-300 text-xs leading-relaxed">
                        يتم تحليل أداء المهام ديناميكياً لكل مهندس ومشرف. يتم احتساب التقييم بناءً على معادلة الإنجاز الفعلي للمهام المقفلة والمسندة للفرد لتحقيق الشفافية الكاملة في المتابعة.
                    </p>
                </div>

                <!-- نموذج إضافة موظف -->
                <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-sm space-y-4">
                    <h4 class="text-sm font-bold text-gray-700 border-b border-gray-100 pb-2"><i class="fa-solid fa-user-plus text-rmgGold ml-1"></i> إضافة موظف وتحديد قطاعه وبيانات دخوله</h4>
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">اسم الموظف الجديد</label>
                            <input type="text" id="new-user-name" placeholder="الاسم" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">المسمى الوظيفي</label>
                            <input type="text" id="new-user-role" placeholder="المهنة" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">اسم المستخدم (User)</label>
                            <input type="text" id="new-user-username" placeholder="User" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">كلمة المرور (Password)</label>
                            <input type="text" id="new-user-password" placeholder="Password" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                        <div class="col-span-2">
                            <label class="block text-[11px] text-gray-500 mb-1">القطاع الفني</label>
                            <select id="new-user-sector" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                                <option value="إدارة الدعم والتقنية">إدارة الدعم والتقنية</option>
                                <option value="الإدارة العامة والمالية">الإدارة العامة والمالية</option>
                                <option value="إدارة الموارد اللوجستية">إدارة الموارد اللوجستية</option>
                                <option value="إدارة المشروعات والتشطيبات">إدارة المشروعات والتشطيبات</option>
                            </select>
                        </div>
                    </div>
                    <button onclick="addUser()" class="w-full bg-rmgGreen text-white py-2.5 rounded-xl text-sm font-bold hover:bg-emerald-900 transition">حفظ الموظف</button>
                </div>

                <!-- نموذج صرف عهدة معدات -->
                <div class="bg-white p-5 rounded-2xl border border-gray-200 shadow-sm space-y-4">
                    <h4 class="text-sm font-bold text-gray-700 border-b border-gray-100 pb-2"><i class="fa-solid fa-hand-holding-hand text-emerald-700 ml-1"></i> نموذج تسليم عهدة معدات من المستودع</h4>
                    <div class="grid grid-cols-1 gap-3">
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">اختر الموظف المستلم</label>
                            <select id="custody-user-select" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen"></select>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-[11px] text-gray-500 mb-1">اختر المعدة</label>
                                <select id="custody-item-select" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen"></select>
                            </div>
                            <div>
                                <label class="block text-[11px] text-gray-500 mb-1">الالكمية المسحوبة</label>
                                <input type="number" id="custody-item-qty" value="1" min="1" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                            </div>
                        </div>
                        <div>
                            <label class="block text-[11px] text-gray-500 mb-1">ملاحظات الصرف والعهدة</label>
                            <input type="text" id="custody-notes" placeholder="مثال: استخدام ميداني بالمشروع" class="w-full bg-gray-50 border border-gray-200 px-3 py-2 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        </div>
                    </div>
                    <button onclick="assignCustody()" class="w-full bg-amber-600 text-white py-2.5 rounded-xl text-sm font-bold hover:bg-amber-700 transition shadow-sm">إصدار وإسناد عهدة المعدات</button>
                </div>

                <!-- قائمة الموظفين واستعراض عهدهم والـ KPI المحدث لحظياً -->
                <div id="users-list-container" class="space-y-3"></div>
            </div>
        </main>

        <!-- الزر العائم لإنشاء مهمة جديدة -->
        <div id="floating-btn" class="fixed bottom-24 left-6 z-40">
            <button onclick="openModal()" class="w-14 h-14 bg-emerald-800 hover:bg-emerald-700 text-white rounded-full flex items-center justify-center shadow-xl transition transform active:scale-95">
                <i class="fa-solid fa-plus text-2xl"></i>
            </button>
        </div>

        <!-- ================= شريط التنقل السفلي ================= -->
        <div id="bottom-nav" class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 py-3 shadow-2xl z-40">
            <div class="max-w-xl mx-auto flex justify-around items-center px-2">
                <div id="nav-tasks" onclick="switchSection('tasks', this)" class="nav-btn flex flex-col items-center gap-1 text-rmgGreen font-bold cursor-pointer transition">
                    <i class="fa-solid fa-list-check text-lg"></i>
                    <span class="text-xs">المهام</span>
                </div>
                <div id="nav-projects" onclick="switchSection('projects', this)" class="nav-btn flex flex-col items-center gap-1 text-gray-400 cursor-pointer transition">
                    <i class="fa-solid fa-diagram-project text-lg"></i>
                    <span class="text-xs">المشاريع</span>
                </div>
                <div id="nav-sectors" onclick="switchSection('sectors', this)" class="nav-btn flex flex-col items-center gap-1 text-gray-400 cursor-pointer transition">
                    <i class="fa-solid fa-chart-pie text-lg"></i>
                    <span class="text-xs">القطاعات</span>
                </div>
                <div id="nav-inventory" onclick="switchSection('inventory', this)" class="nav-btn flex flex-col items-center gap-1 text-gray-400 cursor-pointer transition">
                    <i class="fa-solid fa-warehouse text-lg"></i>
                    <span class="text-xs">المستودع</span>
                </div>
                <div id="nav-team" onclick="switchSection('team', this)" class="nav-btn flex flex-col items-center gap-1 text-gray-400 cursor-pointer transition">
                    <i class="fa-solid fa-users text-lg"></i>
                    <span class="text-xs">الفريق والـ KPI</span>
                </div>
            </div>
        </div>
    </div>

    <!-- النافذة المنبثقة لإنشاء وتعديل المهام -->
    <div id="task-modal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center p-4 z-50">
        <div class="bg-white w-full max-w-md rounded-2xl p-6 shadow-2xl overflow-y-auto max-h-[90vh]">
            <h3 id="modal-title" class="text-lg font-bold text-rmgGreen mb-4">إنشاء تكليف جديد</h3>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs text-gray-500 mb-1">وصف المهمة الهندسية / الإدارية</label>
                    <input type="text" id="modal-task-title" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-sm outline-none focus:border-rmgGreen">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">اسم المشروع</label>
                    <input type="text" id="modal-task-project" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-sm outline-none focus:border-rmgGreen">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">المدة المتوقعة</label>
                    <input type="text" id="modal-task-duration" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-sm outline-none focus:border-rmgGreen">
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">القطاع المسؤول</label>
                    <select id="modal-task-sector" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        <option value="إدارة المشروعات والتشطيبات">إدارة المشروعات والتشطيبات</option>
                        <option value="إدارة الدعم والتقنية">إدارة الدعم والتقنية</option>
                        <option value="الإدارة العامة والمالية">الإدارة العامة والمالية</option>
                        <option value="إدارة الموارد اللوجستية">إدارة الموارد اللوجستية</option>
                    </select>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <label class="block text-xs text-gray-500">تعيين المستخدمين المسؤولين</label>
                        <label class="flex items-center gap-1 text-xs text-rmgGreen font-bold cursor-pointer">
                            <input type="checkbox" id="toggle-all-assignees" onchange="toggleSelectAllAssignees(this)"> اختيار الجميع
                        </label>
                    </div>
                    <div id="modal-task-assignees-container" class="bg-gray-50 border border-gray-200 p-3 rounded-xl max-h-36 overflow-y-auto space-y-1.5"></div>
                </div>
                <div>
                    <label class="block text-xs text-gray-500 mb-1">الحالة البدئية</label>
                    <select id="modal-task-status" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-sm outline-none focus:border-rmgGreen">
                        <option value="جديدة">جديدة</option>
                        <option value="قيد الاستلام">قيد الاستلام</option>
                        <option value="قيد التنفيذ">قيد التنفيذ</option>
                        <option value="مكتملة">مكتملة</option>
                    </select>
                </div>
            </div>
            <div class="flex gap-3 mt-6">
                <button onclick="saveTask()" class="flex-1 bg-rmgGreen text-white py-2.5 rounded-xl text-sm font-bold shadow-md hover:bg-emerald-900 transition">حفظ التكليف</button>
                <button onclick="closeModal()" class="flex-1 bg-gray-100 text-gray-600 py-2.5 rounded-xl text-sm transition hover:bg-gray-200">إلغاء</button>
            </div>
        </div>
    </div>

    <!-- جافا سكريبت لتشغيل النظام المطور بمؤشرات KPI -->
    <script>
        // الطاقم الإداري والهندسي الجديد بالكامل مع حسابات الدخول المخصصة والقطاعات والعهَد
        let users = [
