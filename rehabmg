        function applyFilterAndRender() {
            let filtered = tasks;
            const badge = document.getElementById('active-filter-badge');
            const text = document.getElementById('filter-text');

            if (currentProjectFilter) {
                filtered = tasks.filter(t => t.project === currentProjectFilter);
                text.innerHTML = `مشروع: <strong>${currentProjectFilter}</strong>`;
                badge.classList.remove('hidden');
            } else if (currentSectorFilter) {
                filtered = tasks.filter(t => t.sector === currentSectorFilter);
                text.innerHTML = `قطاع: <strong>${currentSectorFilter}</strong>`;
                badge.classList.remove('hidden');
            } else { badge.classList.add('hidden'); }

            const query = document.getElementById('search-input').value.toLowerCase();
            if(query) {
                filtered = filtered.filter(t => 
                    t.title.toLowerCase().includes(query) || 
                    t.assignees.some(name => name.toLowerCase().includes(query))
                );
            }
            renderTasks(filtered);
        }

        function filterTasks() { applyFilterAndRender(); }

