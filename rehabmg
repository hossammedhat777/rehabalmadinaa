        function closeModal() { document.getElementById('task-modal').classList.add('hidden'); }
        
        function saveTask() {
            const title = document.getElementById('modal-task-title').value.trim();
            if(!title) return;

            const selectedAssignees = [];
            document.querySelectorAll('.task-assignee-checkbox:checked').forEach(cb => {
                selectedAssignees.push(cb.value);
            });

            if(selectedAssignees.length === 0) return alert('يرجى تعيين موظف واحد على الأقل للمهمة لحساب كفاءة الأداء!');

            tasks.unshift({
                id: Date.now(),
                title,
                project: document.getElementById('modal-task-project').value.trim() || 'عام',
                sector: document.getElementById('modal-task-sector').value,
                assignees: selectedAssignees,
                status: document.getElementById('modal-task-status').value,
                duration: document.getElementById('modal-task-duration').value || 'غير محددة',
                timestamp: '2026-07-06', comments: [], images: []
            });
            applyFilterAndRender();
            closeModal();
        }

        function deleteTask(id) { if(confirm('حذف المهمة؟ سينعكس الحذف على الـ KPI للفريق.')) { tasks = tasks.filter(t => t.id !== id); applyFilterAndRender(); } }
    </script>
</body>
</html>
